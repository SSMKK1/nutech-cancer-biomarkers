generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DOCTOR
  LAB
  PATIENT
}

enum SampleStatus {
  REGISTERED
  COLLECTED
  IN_TESTING
  COMPLETED
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(PATIENT)

  image String?

  emailNotifications     Boolean @default(true)
  screeningNotifications Boolean @default(true)
  marketingNotifications Boolean @default(false)

  lastLoginAt       DateTime?
  passwordChangedAt DateTime?

  doctorProfile  DoctorProfile?
  labProfile     LaboratoryProfile?
  patientProfile PatientProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DoctorProfile {
  id             String  @id @default(cuid())
  userId         String  @unique
  hospital       String?
  specialization String?
  licenseNumber  String?
  approved       Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  samples Sample[]

  createdAt DateTime @default(now())
}

model LaboratoryProfile {
  id       String  @id @default(cuid())
  userId   String  @unique
  name     String
  location String?
  contact  String?
  approved Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  samples Sample[]

  createdAt DateTime @default(now())
}

model PatientProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  dateOfBirth DateTime?
  gender      String?
  phone       String?

  user User @relation(fields: [userId], references: [id])

  samples Sample[]

  createdAt DateTime @default(now())
}

model Sample {
  id         String @id @default(cuid())
  sampleCode String @unique

  patientId String
  doctorId  String?
  labId     String?

  status SampleStatus @default(REGISTERED)

  patient PatientProfile     @relation(fields: [patientId], references: [id])
  doctor  DoctorProfile?     @relation(fields: [doctorId], references: [id])
  lab     LaboratoryProfile? @relation(fields: [labId], references: [id])

  result Result?

  collectedAt DateTime?
  createdAt   DateTime @default(now())
}

model Result {
  id String @id @default(cuid())

  sampleId String @unique

  biomarkerName  String
  value          String
  interpretation String?

  sample Sample @relation(fields: [sampleId], references: [id])

  createdAt DateTime @default(now())
}

model ContactInquiry {
  id String @id @default(cuid())

  name    String
  email   String
  message String

  createdAt DateTime @default(now())
}

model PartnerApplication {
  id String @id @default(cuid())

  organization String
  contactName  String
  email        String
  message      String

  createdAt DateTime @default(now())
}

model InvestorInquiry {
  id String @id @default(cuid())

  name    String
  company String?
  email   String
  message String

  createdAt DateTime @default(now())
}